# ---- Build output ----
.gradle/
build/
app/build/
/captures/
.externalNativeBuild/
.cxx/
*.apk
*.aab

# ---- IDE / OS ----
.idea/
*.iml
.DS_Store
Thumbs.db

# ---- Local machine config (never commit) ----
local.properties

# ---- Signing keys (not distributed; build falls back to Gradle's debug key) ----
signing/
*.keystore
*.jks

# ---- Vendored platform-tools binaries (supply your own adb) ----
platform-tools/

# ---- Personal screensaver photos (never distributed) ----
# Top-level source photo folder: fully ignored (anchored to repo root).
/screensaver/
# Bundled assets: ignore EVERY file in this folder (any type, so no photo can ever
# slip in) but keep the folder present via its README placeholder.
app/src/main/assets/screensaver/*
!app/src/main/assets/screensaver/README.txt

# ---- Misc ----
*.log
