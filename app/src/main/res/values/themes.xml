<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Compose draws the actual UI; this Android-level theme just controls the
      window before Compose takes over. Black background avoids a white flash.
    -->
    <style name="Theme.GoogleTvLauncher" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
